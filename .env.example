# Copy to .env.local and fill in once your services are ready.

# Supabase — add after creating your project (Project Settings → API).
# Until these are set, the storefront runs on the local seed catalog and the
# admin shows a "connect Supabase" message.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — only needed when enabling online payments.
# Also set SITE.paymentsEnabled = true in src/config/site.ts to go live.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
